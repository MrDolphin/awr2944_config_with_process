# 八、TLV 解析模块骨架

```python id="c3gimz"
import struct
from app.models.point import Point
from app.models.target import Target

TLV_HEADER_LEN = 8

class TLVParser:
    def parse_tlvs(self, payload: bytes, tlv_count: int):
        offset = 0
        result = {
            "points": [],
            "targets": [],
            "status": None,
            "imu": None,
        }

        for _ in range(tlv_count):
            tlv_type, reserved, length = struct.unpack_from("<HHI", payload, offset)
            offset += TLV_HEADER_LEN
            value = payload[offset:offset+length]
            offset += length

            if tlv_type == 0x1001:
                result["points"] = self._parse_points(value)
            elif tlv_type == 0x1002:
                result["targets"] = self._parse_targets(value)
            elif tlv_type == 0x1004:
                result["status"] = self._parse_status(value)

        return result

    def _parse_points(self, value: bytes):
        point_count = struct.unpack_from("<I", value, 0)[0]
        points = []
        offset = 4
        for _ in range(point_count):
            x, y, z, doppler, snr, noise = struct.unpack_from("<ffffff", value, offset)
            offset += 24
            points.append(Point(x, y, z, doppler, snr, noise))
        return points

    def _parse_targets(self, value: bytes):
        target_count = struct.unpack_from("<I", value, 0)[0]
        targets = []
        offset = 4
        for _ in range(target_count):
            item = struct.unpack_from("<Ifffffffff", value, offset)
            offset += 40
            targets.append(
                Target(
                    target_id=item[0],
                    x=item[1], y=item[2], z=item[3],
                    vx=item[4], vy=item[5], vz=item[6],
                    speed=item[7],
                    heading_deg=item[8],
                    confidence=item[9],
                )
            )
        return targets

    def _parse_status(self, value: bytes):
        frame_rate, temperature, cpu_load, error_code, radar_online = struct.unpack("<fffII", value)
        return {
            "fps": frame_rate,
            "temperature": temperature,
            "cpu_load": cpu_load,
            "error_code": error_code,
            "radar_online": bool(radar_online),
        }
```

