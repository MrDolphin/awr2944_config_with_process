# 七、帧解析模块骨架

这个模块负责：

* 找帧头
* 解析 Header
* 找到所有 TLV
* 输出 RadarFrame

```python id="4u7mbc"
import struct
from queue import Queue
from app.io.ring_buffer import RingBuffer

MAGIC = b'\x02\x01\x04\x03\x06\x05\x08\x07'
HEADER_LEN = 40
CRC_LEN = 4

class FrameParser:
    def __init__(self):
        self.buffer = RingBuffer()

    def feed(self, data: bytes):
        self.buffer.append(data)

    def parse_available_frames(self):
        frames = []
        while True:
            idx = self.buffer.find(MAGIC)
            if idx < 0:
                if len(self.buffer) > 4096:
                    self.buffer.discard(len(self.buffer) - 1024)
                break

            if idx > 0:
                self.buffer.discard(idx)

            if len(self.buffer) < len(MAGIC) + HEADER_LEN:
                break

            raw = self.buffer.peek(len(MAGIC) + HEADER_LEN)
            header_bin = raw[len(MAGIC):len(MAGIC)+HEADER_LEN]

            header = self._parse_header(header_bin)
            total_length = header["total_length"]

            if len(self.buffer) < len(MAGIC) + total_length:
                break

            frame_data = self.buffer.read(len(MAGIC) + total_length)
            frames.append(self._parse_frame(frame_data))

        return frames

    def _parse_header(self, data: bytes) -> dict:
        fields = struct.unpack("<HHIIQHHHHIII", data)
        return {
            "version_major": fields[0],
            "version_minor": fields[1],
            "total_length": fields[2],
            "frame_id": fields[3],
            "timestamp_us": fields[4],
            "source_type": fields[5],
            "mode_type": fields[6],
            "tlv_count": fields[7],
            "reserved0": fields[8],
            "device_status": fields[9],
            "reserved1": fields[10],
            "reserved2": fields[11],
        }

    def _parse_frame(self, frame_data: bytes):
        # 这里先留空，后续补TLV解析
        return {
            "raw_frame": frame_data
        }
